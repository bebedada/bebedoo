<!DOCTYPE html>
<html lang="ko">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Comp Card Maker</title>

<script src="https://cdnjs.cloudflare.com/ajax/libs/html2canvas/1.4.1/html2canvas.min.js"></script>

<style>
body{
    font-family:sans-serif;
    background:#f5f5f5;
    margin:0;
    padding:20px;
}

.container{
    display:flex;
    gap:30px;
    flex-wrap:wrap;
}

.form{
    width:300px;
    background:white;
    padding:20px;
    border-radius:10px;
}

.form input{
    width:100%;
    padding:10px;
    margin-bottom:10px;
    box-sizing:border-box;
}

.compcard{
    width:700px;
    background:white;
    padding:20px;
    border-radius:10px;
}

.header{
    text-align:center;
    margin-bottom:20px;
}

.header h1{
    margin:0;
}

.grid{
    display:grid;
    grid-template-columns:1fr 1fr;
    gap:10px;
}

.photo{
    width:100%;
    aspect-ratio:3/4;
    background:#ddd;
    overflow:hidden;
}

.photo img{
    width:100%;
    height:100%;
    object-fit:cover;
}

.info{
    margin-top:20px;
    font-size:18px;
}

button{
    width:100%;
    padding:12px;
    margin-top:10px;
    cursor:pointer;
}
</style>
</head>
<body>

<div class="container">

<div class="form">

<h2>컴카드 정보</h2>

<input id="name" placeholder="이름">
<input id="height" placeholder="키">
<input id="weight" placeholder="몸무게">
<input id="phone" placeholder="연락처">

<label>사진1</label>
<input type="file" accept="image/*" onchange="loadImage(event,0)">

<label>사진2</label>
<input type="file" accept="image/*" onchange="loadImage(event,1)">

<label>사진3</label>
<input type="file" accept="image/*" onchange="loadImage(event,2)">

<label>사진4</label>
<input type="file" accept="image/*" onchange="loadImage(event,3)">

<button onclick="saveData()">자동저장</button>
<button onclick="downloadCard()">JPG 저장</button>

</div>

<div class="compcard" id="card">

<div class="header">
    <h1 id="previewName">MODEL NAME</h1>
</div>

<div class="grid">
    <div class="photo"><img id="img0"></div>
    <div class="photo"><img id="img1"></div>
    <div class="photo"><img id="img2"></div>
    <div class="photo"><img id="img3"></div>
</div>

<div class="info">
    <p>Height : <span id="previewHeight">-</span></p>
    <p>Weight : <span id="previewWeight">-</span></p>
    <p>Phone : <span id="previewPhone">-</span></p>
</div>

</div>

</div>

<script>

const inputs=["name","height","weight","phone"];

inputs.forEach(id=>{
    document.getElementById(id).addEventListener("input",updatePreview);
});

function updatePreview(){

    previewName.innerText=name.value || "MODEL NAME";
    previewHeight.innerText=height.value;
    previewWeight.innerText=weight.value;
    previewPhone.innerText=phone.value;

    saveData();
}

function saveData(){

    localStorage.setItem("compcard_name",name.value);
    localStorage.setItem("compcard_height",height.value);
    localStorage.setItem("compcard_weight",weight.value);
    localStorage.setItem("compcard_phone",phone.value);
}

function loadSaved(){

    name.value=localStorage.getItem("compcard_name") || "";
    height.value=localStorage.getItem("compcard_height") || "";
    weight.value=localStorage.getItem("compcard_weight") || "";
    phone.value=localStorage.getItem("compcard_phone") || "";

    updatePreview();
}

function loadImage(event,index){

    const file=event.target.files[0];

    if(!file) return;

    const reader=new FileReader();

    reader.onload=function(e){

        document.getElementById(
            "img"+index
        ).src=e.target.result;

        localStorage.setItem(
            "image"+index,
            e.target.result
        );
    }

    reader.readAsDataURL(file);
}

function loadImages(){

    for(let i=0;i<4;i++){

        const img=localStorage.getItem("image"+i);

        if(img){
            document.getElementById(
                "img"+i
            ).src=img;
        }
    }
}

function downloadCard(){

    html2canvas(
        document.getElementById("card")
    ).then(canvas=>{

        const link=document.createElement("a");

        link.download="compcard.jpg";

        link.href=canvas.toDataURL();

        link.click();
    });
}

loadSaved();
loadImages();

</script>

</body>
</html>
